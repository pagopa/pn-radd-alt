# Base URL dell'API RADD
API_BASE_URL=https://api.radd.notifichedigitali.it

# Autenticazione Cognito
COGNITO_REGION=eu-central-1
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_USERNAME=user@example.com
COGNITO_PASSWORD=SuperPassword123!

# Opzionali
COGNITO_USE_ID_TOKEN=true
COGNITO_TOKEN_MARGIN=30

# Alternativa: token JWT statico (se impostato, non usa Cognito)
# API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
