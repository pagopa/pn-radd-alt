{
  "name": "radd-private-proxy",
  "version": "1.0.0",
  "description": "AWS Lambda proxy/enforcer for RADD PrivateLink traffic.",
  "main": "index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test-build": "npm run lint && npm run test && npm run coverage && npm run build",
    "lint": "eslint ./index.js ./src/app/*.js ./src/test/*.test.js",
    "coverage": "c8 --reporter=html --reporter=text --reporter=lcov node --test ./src/test/*.test.js",
    "format": "prettier --write .",
    "test": "node --test ./src/test/*.test.js",
    "build": "rm -f ./function.zip && zip -r ./function.zip ./index.js ./package.json ./src -x './src/test/*'"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "c8": "^10.1.3",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2"
  }
}
